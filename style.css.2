* {

.application-grid {
  grid-template-columns: repeat(3, 1fr);
}

.product-card,
.feature-box,
.application-card,
form {
  background: #1e293b;
  padding: 25px;
  border-radius: 20px;
}

.product-card h3,
.feature-box h3 {
  margin: 20px 0 10px;
}

form input,
form textarea {
  width: 100%;
  padding: 14px;
  margin-bottom: 15px;
  border: none;
  border-radius: 8px;
}

footer {
  background: #111827;
  padding: 40px 0;
}

footer ul {
  list-style: none;
}

footer ul li {
  margin-bottom: 10px;
}

footer ul li a {
  color: #cbd5e1;
  text-decoration: none;
}

@media (max-width: 768px) {
  .navbar,
  nav ul,
  .hero-content,
  .about-grid,
  .contact-grid,
  .footer-grid,
  .product-grid,
  .features-grid,
  .application-grid,
  .stats {
    grid-template-columns: 1fr;
    flex-direction: column;
  }

  nav ul {
    flex-direction: column;
    gap: 10px;
  }

  .hero-text h1 {
    font-size: 40px;
  }
}
